{
  "name": "mcp-commerce-server",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "echo 'format not configured'",
    "docs:check": "test -f docs/index.md && test -f public/llms.txt"
  },
  "dependencies": {"dotenv":"^16.4.5","express":"^4.19.2","pino":"^9.3.2","zod":"^3.23.8"},
  "devDependencies": {"@types/express":"^4.17.21","@types/node":"^22.7.4","supertest":"^7.0.0","tsx":"^4.19.1","typescript":"^5.6.2","vitest":"^2.1.2"}
}
